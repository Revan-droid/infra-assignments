{
  "title": "Config Service — Full Observability",
  "uid": "config-service-full",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "timezone": "browser",
  "tags": ["config-service", "go", "platform"],
  "panels": [
    {
      "id": 1, "gridPos": {"x":0,"y":0,"w":4,"h":4},
      "title": "Request Rate (req/s)",
      "type": "stat",
      "options": {"colorMode":"background","graphMode":"area","reduceOptions":{"calcs":["lastNotNull"]}},
      "fieldConfig": {"defaults":{"color":{"mode":"thresholds"},"thresholds":{"steps":[{"color":"green","value":0},{"color":"yellow","value":10},{"color":"red","value":50}]},"unit":"reqps"}},
      "datasource": {"type":"prometheus","uid":"prometheus"},
      "targets": [{"datasource":{"type":"prometheus","uid":"prometheus"},"expr":"sum(rate(http_requests_total[1m]))","legendFormat":"req/s","refId":"A"}]
    },
    {
      "id": 2, "gridPos": {"x":4,"y":0,"w":4,"h":4},
      "title": "Error Rate (%)",
      "type": "stat",
      "options": {"colorMode":"background","reduceOptions":{"calcs":["lastNotNull"]}},
      "fieldConfig": {"defaults":{"color":{"mode":"thresholds"},"thresholds":{"steps":[{"color":"green","value":0},{"color":"yellow","value":1},{"color":"red","value":5}]},"unit":"percent"}},
      "datasource": {"type":"prometheus","uid":"prometheus"},
      "targets": [{"datasource":{"type":"prometheus","uid":"prometheus"},"expr":"sum(rate(http_requests_total{status=~\"5..\"}[1m])) / sum(rate(http_requests_total[1m])) * 100","legendFormat":"error %","refId":"A"}]
    },
    {
      "id": 3, "gridPos": {"x":8,"y":0,"w":4,"h":4},
      "title": "P99 Latency",
      "type": "stat",
      "options": {"colorMode":"background","reduceOptions":{"calcs":["lastNotNull"]}},
      "fieldConfig": {"defaults":{"color":{"mode":"thresholds"},"thresholds":{"steps":[{"color":"green","value":0},{"color":"yellow","value":0.5},{"color":"red","value":1}]},"unit":"s"}},
      "datasource": {"type":"prometheus","uid":"prometheus"},
      "targets": [{"datasource":{"type":"prometheus","uid":"prometheus"},"expr":"histogram_quantile(0.99, sum(rate(request_duration_seconds_bucket[5m])) by (le))","legendFormat":"p99","refId":"A"}]
    },
    {
      "id": 4, "gridPos": {"x":12,"y":0,"w":4,"h":4},
      "title": "Config Upserts (5m)",
      "type": "stat",
      "options": {"colorMode":"background","graphMode":"area","reduceOptions":{"calcs":["lastNotNull"]}},
      "fieldConfig": {"defaults":{"color":{"fixedColor":"blue","mode":"fixed"},"unit":"short"}},
      "datasource": {"type":"prometheus","uid":"prometheus"},
      "targets": [{"datasource":{"type":"prometheus","uid":"prometheus"},"expr":"increase(config_upserts_total[5m])","legendFormat":"upserts","refId":"A"}]
    },
    {
      "id": 5, "gridPos": {"x":16,"y":0,"w":4,"h":4},
      "title": "Config Reads (5m)",
      "type": "stat",
      "options": {"colorMode":"background","graphMode":"area","reduceOptions":{"calcs":["lastNotNull"]}},
      "fieldConfig": {"defaults":{"color":{"fixedColor":"purple","mode":"fixed"},"unit":"short"}},
      "datasource": {"type":"prometheus","uid":"prometheus"},
      "targets": [{"datasource":{"type":"prometheus","uid":"prometheus"},"expr":"increase(config_reads_total[5m])","legendFormat":"reads","refId":"A"}]
    },
    {
      "id": 6, "gridPos": {"x":20,"y":0,"w":4,"h":4},
      "title": "Kafka Events (5m)",
      "type": "stat",
      "options": {"colorMode":"background","graphMode":"area","reduceOptions":{"calcs":["lastNotNull"]}},
      "fieldConfig": {"defaults":{"color":{"fixedColor":"orange","mode":"fixed"},"unit":"short"}},
      "datasource": {"type":"prometheus","uid":"prometheus"},
      "targets": [{"datasource":{"type":"prometheus","uid":"prometheus"},"expr":"increase(kafka_messages_total[5m])","legendFormat":"events","refId":"A"}]
    },
    {
      "id": 7, "gridPos": {"x":0,"y":4,"w":12,"h":8},
      "title": "HTTP Request Rate by Method & Status",
      "type": "timeseries",
      "options": {"tooltip":{"mode":"multi"}},
      "fieldConfig": {"defaults":{"unit":"reqps","custom":{"lineWidth":2}}},
      "datasource": {"type":"prometheus","uid":"prometheus"},
      "targets": [
        {"datasource":{"type":"prometheus","uid":"prometheus"},"expr":"sum(rate(http_requests_total[1m])) by (method, status)","legendFormat":"{{method}} {{status}}","refId":"A"}
      ]
    },
    {
      "id": 8, "gridPos": {"x":12,"y":4,"w":12,"h":8},
      "title": "Request Latency Percentiles",
      "type": "timeseries",
      "options": {"tooltip":{"mode":"multi"}},
      "fieldConfig": {"defaults":{"unit":"s","custom":{"lineWidth":2}}},
      "datasource": {"type":"prometheus","uid":"prometheus"},
      "targets": [
        {"datasource":{"type":"prometheus","uid":"prometheus"},"expr":"histogram_quantile(0.50, sum(rate(request_duration_seconds_bucket[5m])) by (le))","legendFormat":"p50","refId":"A"},
        {"datasource":{"type":"prometheus","uid":"prometheus"},"expr":"histogram_quantile(0.95, sum(rate(request_duration_seconds_bucket[5m])) by (le))","legendFormat":"p95","refId":"B"},
        {"datasource":{"type":"prometheus","uid":"prometheus"},"expr":"histogram_quantile(0.99, sum(rate(request_duration_seconds_bucket[5m])) by (le))","legendFormat":"p99","refId":"C"}
      ]
    },
    {
      "id": 9, "gridPos": {"x":0,"y":12,"w":12,"h":8},
      "title": "HTTP Request Rate by Path",
      "type": "timeseries",
      "fieldConfig": {"defaults":{"unit":"reqps","custom":{"lineWidth":2}}},
      "datasource": {"type":"prometheus","uid":"prometheus"},
      "targets": [
        {"datasource":{"type":"prometheus","uid":"prometheus"},"expr":"sum(rate(http_requests_total[1m])) by (path)","legendFormat":"{{path}}","refId":"A"}
      ]
    },
    {
      "id": 10, "gridPos": {"x":12,"y":12,"w":12,"h":8},
      "title": "Request Latency by Path (p95)",
      "type": "timeseries",
      "fieldConfig": {"defaults":{"unit":"s","custom":{"lineWidth":2}}},
      "datasource": {"type":"prometheus","uid":"prometheus"},
      "targets": [
        {"datasource":{"type":"prometheus","uid":"prometheus"},"expr":"histogram_quantile(0.95, sum(rate(request_duration_seconds_bucket[5m])) by (le, path))","legendFormat":"p95 {{path}}","refId":"A"}
      ]
    },
    {
      "id": 11, "gridPos": {"x":0,"y":20,"w":24,"h":10},
      "title": "Application Logs (Loki)",
      "type": "logs",
      "options": {"dedupStrategy":"none","enableLogDetails":true,"prettifyLogMessage":true,"showTime":true,"sortOrder":"Descending"},
      "datasource": {"type":"loki","uid":"loki"},
      "targets": [
        {"datasource":{"type":"loki","uid":"loki"},"expr":"{container=\"config-service\"} | json","legendFormat":"","refId":"A"}
      ]
    }
  ]
}
